{
  "compilerOptions": {
    "baseUrl": "src",
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./*"],
      "@": ["./"]
    },
    "noEmit": true,
    "noUnusedLocals": false, // 检查是否存在未使用的变量
    "noUnusedParameters": false // 检查是否存在会使用的函数参数
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "src/plugins/locale.js"
  ]
  // "references": [{ "path": "./tsconfig.node.json" }]
}
